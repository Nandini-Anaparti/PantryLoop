{
  "name": "pantryloop",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered grocery, food waste, meal planning, and responsible disposal assistant.",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "functions"
  ],
  "scripts": {
    "build:packages": "tsc -b packages/shared packages/firebase --pretty false",
    "typecheck": "tsc -b packages/shared packages/firebase functions --pretty false",
    "typecheck:shared": "tsc -b packages/shared --pretty false",
    "lint:secrets": "node scripts/check-no-secrets.mjs",
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --workspace @pantryloop/web",
    "build:web": "npm run build --workspace @pantryloop/web",
    "start:web": "npm run start --workspace @pantryloop/web",
    "typecheck:web": "npm run typecheck --workspace @pantryloop/web"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
